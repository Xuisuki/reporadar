# Copy to .env and fill in. / Скопируйте в .env и заполните.

# ---- Telegram ----
# Bot token from @BotFather. The bot must be an ADMIN of the channel.
GH_TREND_BOT_TOKEN=
# Channel id: public @username or numeric -100...  (find it: python bot.py chatid)
GH_TREND_CHANNEL_ID=

# ---- LLM (any OpenAI-compatible provider) ----
# 1 = generate RU descriptions and run the judge, 0 = disable all LLM calls.
USE_AI=1
# Default: local Ollama (free, no key). See README "Connect any LLM" for others.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
# Cloud providers (Groq/OpenAI/OpenRouter/together): set the key here...
# LLM_API_KEY=
# ...or point to a file with one key per line (rotated on rate-limit):
# LLM_API_KEY_FILE=

# ---- GitHub (optional) ----
# Token to raise the Search API rate limit. Works without it on a lower limit.
# GITHUB_TOKEN=
# GITHUB_TOKEN_FILE=

# ---- "needle in a haystack" selection ----
# Star window: the invisibility band where hidden gems live.
NEEDLE_STARS_MIN=150
NEEDLE_STARS_MAX=2500
# "rockets": young fast-risers (created within N days, own star ceiling)
NEEDLE_ROCKET_AGE=60
NEEDLE_ROCKET_STARS_MAX=1500
# "evergreen": old but alive (pushed within N days)
NEEDLE_EVERGREEN_PUSH=90
# LLM judge: how many top candidates to score, and the minimum score (1-10)
NEEDLE_JUDGE_TOPK=6
NEEDLE_JUDGE_MIN=7
NEEDLE_USE_JUDGE=1
# Product screenshot from README on the card (1 = hybrid, 0 = synthetic only)
NEEDLE_SCREENSHOT=1

# ---- misc ----
# Timezone for dates on the card.
TZ=Europe/Moscow
# Posting interval is set in the scheduler (deploy/reporadar.timer), not here.
